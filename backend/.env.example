NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/marketili?retryWrites=true&w=majority
JWT_SECRET=replace_with_64_char_random_string_run_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins (production only)
CORS_ORIGIN=https://your-netlify-site.netlify.app

# ── Chargily Pay V2 ───────────────────────────────────────────────────────────
# test = https://pay.chargily.net/test/api/v2 | live = https://pay.chargily.net/api/v2
CHARGILY_MODE=test
# Your secret key from the Chargily Developers Corner (test_sk_... or live_sk_...)
CHARGILY_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional dedicated webhook secret (falls back to CHARGILY_SECRET_KEY)
CHARGILY_WEBHOOK_SECRET=
# Frontend origin Chargily redirects back to after checkout
FRONTEND_URL=http://localhost:3000
# Public URL of this backend (used for the webhook endpoint). Use an https
# tunnel for local webhooks; otherwise the on-return /verify flow handles test mode.
BACKEND_PUBLIC_URL=http://localhost:5000
